// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`
enum ZonaGeografica{
  LA_PAZ
  EL_ALTO
}

enum TipoDeInstitucion{
  // 🏥 Atención médica y prevención
  SALUD                  
  
  // 🛡️ Puntos de denuncia directa y protección
  POLICIAL               
  
  // ⚖️ Apoyo legal y seguimiento de casos
  LEGAL_JUSTICIA         
  
  // 🤝 Servicios municipales de apoyo social/psicológico
  DEFENSORIA             
  
  // 💜 Organizaciones de la sociedad civil
  ONG_FUNDACION          
  
}


generator client {
  provider = "prisma-client-js" 
  // ¡Fíjate en el "-js" al final! 
  // Ya no necesitas la línea "output" aquí.
}

datasource db {
  provider = "postgresql"
}
model Usuario{
  Id Int  @id @default(autoincrement())
  Nombre String @db.VarChar(50)
  Apellido String @db.VarChar(50)
  Email String @unique @db.VarChar(100)
  
  Password Password?
}
model Password{
  Id Int @id @default(autoincrement())
  PasswordHash String
  IdUsuario Int @unique

  Usuario Usuario @relation(fields: [IdUsuario], references: [Id])
}

model Institucion{
  Id Int @id @default(autoincrement())
  NombreInstitucion String
  TipoInstitucion TipoDeInstitucion

  NumeroTel String? @db.VarChar(20)
  Descripcion String @db.VarChar(1000)

  Ubicacion Ubicacion?
}

model Ubicacion{
  Id Int @id @default(autoincrement())
  Longitud Float
  Latitud Float
  Zona ZonaGeografica

  IdInstitucion Int @unique
  Institucion Institucion @relation(fields: [IdInstitucion],references: [Id])
}
